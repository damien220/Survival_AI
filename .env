# =============================================================================
# AI Survival - Environment Configuration
# =============================================================================
# This file configures the Docker Compose stack for the offline LLM platform.
# Adjust these values to match your hardware and preferences.

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Default GGUF model filename (must exist in ./models/ directory)
DEFAULT_MODEL=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# -----------------------------------------------------------------------------
# Port Configuration
# -----------------------------------------------------------------------------
# llama.cpp server API port
LLAMA_PORT=8080

# Open WebUI port (access the chat UI at http://localhost:WEBUI_PORT)
WEBUI_PORT=3000

# -----------------------------------------------------------------------------
# Inference Configuration
# -----------------------------------------------------------------------------
# Context window size (tokens). Larger = more memory, longer conversations.
# Recommended: 2048 for low-RAM systems, 4096 default, 8192 for 16GB+ RAM
CONTEXT_SIZE=4096

# Number of layers to offload to GPU (0 = CPU-only)
# Set to -1 to offload all layers (requires NVIDIA GPU with CUDA)
GPU_LAYERS=0

# Number of CPU threads for inference
# Recommended: set to your physical core count (not hyperthreads)
# 0 = auto-detect
THREADS=0

# Batch size for prompt processing
BATCH_SIZE=512

# -----------------------------------------------------------------------------
# Open WebUI Configuration
# -----------------------------------------------------------------------------
# Disable authentication (single-user offline use)
WEBUI_AUTH=false

# Compose project name (avoids conflicts with other Docker projects)
COMPOSE_PROJECT_NAME=ai-survival
